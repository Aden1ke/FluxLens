# Copy this file to .env and fill in your real values
# NEVER commit .env — only .env.example goes in git

# ── Gemini / Google AI Studio ──────────────────────
# Get yours at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Google Cloud ────────────────────────────────────
# Your GCP project ID (enables Cloud DLP frame redaction)
GCP_PROJECT_ID=

# ── Frontend ────────────────────────────────────────
# WebSocket URL of your deployed backend
# Local dev:      ws://localhost:8080/ws/session
# Cloud Run:      wss://codelive-backend-xxxx-uc.a.run.app/ws/session
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/session

# ── VS Code Helper (vscode-helper/.env) ─────────────
# URL of your running backend
CODELIVE_BACKEND=http://localhost:8080
# Your active session ID (copy from browser console after connecting)
CODELIVE_SESSION_ID=dev
